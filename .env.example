# ──────────────────────────────────────────────────────────────────────────────
# UX Evaluation Framework — Variables de entorno
# ──────────────────────────────────────────────────────────────────────────────
#
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena los valores de tu proyecto en Supabase Dashboard:
#    https://supabase.com/dashboard/project/<tu-proyecto>/settings/api
#
#    · Project URL  → VITE_SUPABASE_URL
#    · anon / public key → VITE_SUPABASE_ANON_KEY
#
# NUNCA subas .env al repositorio.
# En Vercel configura estas mismas variables en:
#   Project Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
